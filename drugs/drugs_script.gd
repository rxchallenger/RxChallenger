func _ready() -> void:
	print("N of Drugs in app: ",get_child_count())

#region Drug Button Testing
	for x in get_children():
		if x.texture == null:
			print("null texture = ",x.name)
		elif x.name.containsn("0123456789~!@#$%^&*()-+/?><.;{}"):
			print("drugs button containing number/sepcialchar = ",x.name)
		else :
			pass
#endregion

	var gen_keys = generic_dictionary.keys()
	var gen_values = generic_dictionary.values()
	var alt_keys = alternatives_dictionary.keys()
	var data_keys = drugdata_dictionary.keys()

#region Dictionary Testing
	for value in gen_keys:
		if gen_keys.count(value) > 1:
			print("repeated trade name = ",value + ",Count = ",gen_keys.count(value))

	for value in gen_values:
		if gen_values.count(value) > 1:
			break
			print("repeated generic name = ",value + ",Count = ",gen_values.count(value))

	for value in alt_keys:
		if alt_keys.count(value) > 1:
			print("repeated alt name = ",value + ",Count = ",alt_keys.count(value))

	for value in data_keys:
		if data_keys.count(value) > 1:
			print("repeated drug data name = ",value + ",Count = ",data_keys.count(value))

#endregion
